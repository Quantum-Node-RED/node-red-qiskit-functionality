    {
        "id": "function_init",
        "type": "function",
        "z": "e0e96aefa5eab89e",
        "name": "Initialize Count",
        "func": "flow.set('winCount', 0);\nflow.set('loseCount', 0);\nflow.set('count', 0);\nmsg.payload = {iterations: 1000};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 520,
        "y": 380,
        "wires": [
            [
                "function_loop_control"
