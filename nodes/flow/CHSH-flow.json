        ]
    },
    {
        "id": "function_loop_control",
        "type": "function",
        "z": "e0e96aefa5eab89e",
        "name": "Loop Control",
        "func": "let count = flow.get('count') || 0;\nlet iterations = msg.payload.iterations;\ncount += 1;\nflow.set('count', count);\n\nif (count <= iterations) {\n    return [msg, null];\n} else {\n    flow.set('count', 0);\n    return [null, {payload: {iterations: iterations}}];\n}",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 700,
        "y": 380,
