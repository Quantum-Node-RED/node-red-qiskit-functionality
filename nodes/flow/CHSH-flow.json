    {
        "id": "function_countWinLose",
        "type": "function",
        "z": "e0e96aefa5eab89e",
        "name": "Count Win/Lose",
        "func": "var winCount = flow.get('winCount') || 0;\nvar loseCount = flow.get('loseCount') || 0;\n\nif (msg.payload.result.result && typeof msg.payload.result.result === 'string') {\n    if (msg.payload.result.result.toLowerCase()== \"win\") {\n        winCount += 1;\n        flow.set('winCount', winCount);\n    } else if (msg.payload.result.result.toLowerCase()== \"lose\") {\n        loseCount += 1;\n        flow.set('loseCount', loseCount);\n    }\n}\n\nmsg.payload.winCount = winCount;\nmsg.payload.loseCount = loseCount;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1220,
        "y": 380,
        "wires": [
            [
                "function_loop_control"
            ]
        ]
    },
    {
        "id": "function_calculate_percentage",
        "type": "function",
        "z": "e0e96aefa5eab89e",
        "name": "Calculate Win Percentage",
        "func": "let winCount = flow.get('winCount') || 0;\nlet iterations = msg.payload.iterations;\n\nlet winPercentage = (winCount / iterations) * 100;\n\nreturn { payload: `Win Percentage: ${winPercentage}%` };",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
